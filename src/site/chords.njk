        function triggerNoteOn(e) {
            clearTimeout(chordFadeTimeout);
            clearTimeout(completeFadeTimeout);
            clearTimeout(noteReleaseTimeout);
            noteReleaseTimeout = null;
            isMidiFading = false;
            const t = document.getElementById("chord-display");
