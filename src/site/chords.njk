        function drawTrails() {
            if ("piano" !== currentInstrument) return requestAnimationFrame(drawTrails);
            ctx.clearRect(0, 0, canvas.width, canvas.height);
            const e = performance.now();
            const t = getComputedStyle(document.documentElement);
            const n = t.getPropertyValue("--pressed-white-bg").trim();
            const a = t.getPropertyValue("--pressed-black-bg").trim();
            const o = t.getPropertyValue("--top-gradient-white-colour").trim();
            const i = t.getPropertyValue("--top-gradient-black-colour").trim();
            
            const s = ctx.createLinearGradient(0, 0, canvas.width, canvas.height);
            s.addColorStop(.2, o);
            s.addColorStop(.6, n);
            
            const l = ctx.createLinearGradient(0, 0, canvas.width, canvas.height);
            l.addColorStop(.2, i);
            l.addColorStop(.6, a);
            
            for (let t = trails.length - 1; t >= 0; t--) {
                const n = trails[t], a = keyPositions[n.note];
                if (!a) continue;
                const o = canvas.height - .15 * (e - n.startTime);
                let i = canvas.height;
                if (!n.active) i = canvas.height - .15 * (e - n.endTime);
                
                if (i < 0) {
                    trails.splice(t, 1);
                } else {
                    ctx.fillStyle = a.isBlack ? l : s;
                    ctx.beginPath();
                    ctx.roundRect(a.x + 2, o, a.w - 4, i - o, 4);
                    ctx.fill();
                }
            }
            requestAnimationFrame(drawTrails);
        }

