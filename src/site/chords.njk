<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width,initial-scale=1">
    <title>MIDI Chord Reader &amp; Instrument Visualiser</title>
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin="">
    <link href="https://fonts.googleapis.com/css2?family=Karla:ital,wght@0,400;0,700;1,400;1,700&amp;display=swap" rel="stylesheet">
    <style>
        .home-button { text-decoration: none; position: fixed; top: .5vw; left: 1vw; z-index: 100; color: #c0caf5; display: flex; align-items: center; cursor: cell; }
        .home-button h1 { margin: 0; font-weight: 700; font-size: inherit; font: initial; background: linear-gradient(to right, #ff3c00, #ff8f00); -webkit-background-clip: text; -webkit-text-fill-color: transparent; }
        .home-button h1::before { content: " "; display: inline-block; width: 1em; height: 1.2em; background-size: contain; background-repeat: no-repeat; background-image: url(/img/logo.svg); background-position: bottom; vertical-align: top; margin-right: 10px; }
        :root { --chord-text-colour: #ff8f00; --top-gradient-white-colour: #ff3c00; --top-gradient-black-colour: #4b9aff; --white-key-bg: #CAE5FF; --black-key-bg: #12355B; --pressed-white-bg: #ff8f00; --pressed-black-bg: #ff00cb; --fretboard-bg: #2e221b; --fret-wire-colour: #565f89; --string-colour: #a9b1d6; --bg-colour: #1a1b26; --panel-bg: #24283b; }
        body { font-family: Karla, sans-serif; display: flex; flex-direction: column; align-items: center; justify-content: center; height: 100vh; background: linear-gradient(to bottom right, var(--bg-colour), #24283b); background-attachment: fixed; color: #c0caf5; margin: 0; padding: 0; box-sizing: border-box; overflow: hidden; }
        #status { position: fixed; top: 20px; left: 50%; transform: translateX(-50%); color: #cae5ff; }
        #chord-display { font-family: Kinnari, Karla, sans-serif; font-size: clamp(3rem, 10vw, 15vh); font-weight: 400; position: fixed; top: 4vh; left: 0; width: 100vw; display: grid; grid-template-columns: 20vw 1fr 20vw; align-items: baseline; filter: drop-shadow(.2em .2em .4em rgba(0,0,0,.5)); padding: 0; }
        #chord-degree { grid-column: 1; justify-self: end; align-self: baseline; min-width: 2.4ch; text-align: right; font-size: .45em; line-height: 1; color: #c0caf5; opacity: .95; white-space: nowrap; padding-right: .8ch; }
        #chord-name { grid-column: 2; justify-self: center; align-self: baseline; display: inline-flex; align-items: baseline; text-align: center; white-space: nowrap; line-height: 1.2; padding-bottom: .1em; margin: 0; }
        .chord-gradient-text { background: linear-gradient(to bottom right, var(--chord-text-colour), var(--pressed-white-bg)); -webkit-background-clip: text; -webkit-text-fill-color: transparent; background-clip: text; color: transparent; line-height: 1.2; }
        .instrument-wrapper { position: absolute; bottom: 5px; left: 5px; width: calc(100vw - 10px); max-width: none; overflow-x: auto; -webkit-overflow-scrolling: touch; display: flex; flex-direction: column; align-items: center; max-height: 70%; }
        #trails-canvas { display: block; margin: 0 auto; background: 0 0; width: 100%; }
        #piano { position: relative; display: flex; height: clamp(100px, 20vh, 20vh); width: 100%; margin: 0 auto; }
        .black-key, .white-key { box-sizing: border-box; transition: background-color .1s, opacity .3s; display: flex; align-items: flex-end; justify-content: center; padding-bottom: 10px; font-size: .75rem; color: #1a1b26; font-weight: 700; user-select: none; }
        .white-key { height: 100%; background-color: var(--white-key-bg); border: 1px solid #1a1b26; border-radius: 0 0 5px 5px; position: relative; }
        .key-label { z-index: 2; position: relative; pointer-events: none; }
        .black-key.in-scale::after, .white-key.in-scale::after { content: ''; position: absolute; bottom: 0; left: 0; width: 100%; height: 6px; border-radius: 0 0 4px 4px; pointer-events: none; }
        .white-key.in-scale::after { background-color: var(--pressed-white-bg); filter: brightness(1); }
        .black-key.in-scale::after { background-color: var(--pressed-black-bg); filter: brightness(1); }
        .black-key { height: 60%; background-color: var(--black-key-bg); position: absolute; border-radius: 0 0 4px 4px; z-index: 10; color: #c0caf5; }
        .white-key.active { background-color: var(--pressed-white-bg)!important; opacity: 1!important; }
        .black-key.active { background-color: var(--pressed-black-bg)!important; opacity: 1!important; }
        .white-key.hover-chord-key { box-shadow: inset 0 0 0 4px #9ece6a!important; }
        .black-key.hover-chord-key { box-shadow: inset 0 0 0 3px #9ece6a!important; }
        
        /* Guitar Fretboard Global Layout */
        #fretboard-container { display: none; flex-direction: column; background-color: var(--fretboard-bg); border: 3px solid #111; border-radius: 8px; margin: 0 auto; position: relative; box-shadow: 0 10px 30px rgba(0,0,0,.5); }
        .string-row { display: flex; position: relative; height: 35px; align-items: center; }
        .string-line { position: absolute; left: 0; right: 0; top: 50%; transform: translateY(-50%); background-color: var(--string-colour); z-index: 1; box-shadow: 0 2px 4px rgba(0,0,0,.6); }
        .string-row:first-child .string-line { height: 1px; }
        .string-row:nth-child(2) .string-line { height: 1.5px; }
        .string-row:nth-child(3) .string-line { height: 2px; }
        .string-row:nth-child(4) .string-line { height: 2.5px; }
        .string-row:nth-child(5) .string-line { height: 3px; }
        .string-row:nth-child(6) .string-line { height: 4px; }
        .fret-cell { width: 70px; height: 100%; border-right: 3px solid var(--fret-wire-colour); display: flex; justify-content: center; align-items: center; position: relative; z-index: 2; flex-shrink: 0; }
        .fret-cell.nut { border-right: 8px solid #c0caf5; background-color: #111; width: 40px; }
        .fret-marker { width: 22px; height: 22px; border-radius: 50%; background-color: #c0caf5; color: #12355B; font-size: .6rem; display: flex; justify-content: center; align-items: center; transition: background-color .1s, opacity .3s, transform .1s, box-shadow .1s; font-weight: bold;}
        .fret-number-row { display: flex; height: 20px; align-items: center; color: #565f89; font-size: .8rem; font-weight: 700; }
        .fret-number-cell { width: 70px; text-align: center; flex-shrink: 0; }
        .fret-number-cell.nut-label { width: 40px; }
        
        /* Absolute Override Specificity Logic */
        .hide-labels .fret-marker { visibility: hidden; }
        .labels-white-only .black-key-fret .fret-marker { visibility: hidden; }
        .labels-black-only .white-key-fret .fret-marker { visibility: hidden; }
        
        .hide-labels .in-scale .fret-marker,
        .labels-white-only .black-key-fret.in-scale .fret-marker,
        .labels-black-only .white-key-fret.in-scale .fret-marker { visibility: visible; }

        /* Fret Marker Highlighting States */
        .fret-cell.in-scale .fret-marker {background-color: var(--chord-text-colour); color: #fff; box-shadow: 0 0 10px rgba(255,143,0,.5); filter: brightness(1.1);}
        
        /* White Key / Natural Note Active Ring */
        .white-key-fret .fret-marker.active { box-shadow: 0 0 0 3px var(--pressed-white-bg); background-color: #fff; color: #000; filter: brightness(1.2); transform: scale(1.2); visibility: visible; }
        
        /* Black Key / Accidental Note Active Ring */
        .black-key-fret .fret-marker.active { box-shadow: 0 0 0 3px var(--pressed-black-bg); background-color: #fff; color: #000; filter: brightness(1.2); transform: scale(1.2); visibility: visible; }
        
        /* Diatonic Hover Green Ring */
        .fret-marker.hover-chord-fret { box-shadow: 0 0 0 3px #9ece6a !important; filter: brightness(1.2); transform: scale(1.2); visibility: visible !important;}

        .controls-container { position: fixed; top: 2.5rem; left: 1vw; display: grid; gap: .4vw; align-items: center; flex-wrap: wrap; justify-content: flex-start; z-index: 50; max-width: 95vw; }
        button, select { font-family: Karla, sans-serif; background-color: #24283b; border: 1px solid #414868; padding: 2px 2px; border-radius: 5px; font-size: .8rem; cursor: cell; color: #cae5ff; width: 12rem}
        #diatonic-chords-container { grid-column: 1/-1; display: flex; flex-direction: column; gap: 2px; margin-top: 10px; font-size: .8rem; }
        .diatonic-chord-item { color: #c0caf5; cursor: cell; transition: color .1s; }
        .diatonic-chord-item.active { color: var(--pressed-white-bg); font-weight: 700; text-decoration: underline; }
        .diatonic-chord-item:hover { color: var(--pressed-white-bg); }
        #settings-panel { display: none; position: fixed; top: 50%; left: 50%; transform: translate(-50%,-50%); background-color: #24283b; padding: 20px; border-radius: 10px; border: 1px solid #414868; z-index: 100; box-shadow: 0 10px 30px rgba(0,0,0,.8); min-width: 320px; max-height: 80vh; overflow-y: auto; }
        .setting-row { display: flex; justify-content: space-between; align-items: center; margin-bottom: 12px; gap: 20px; }
        .setting-section-title { margin: 20px 0 10px 0; padding-bottom: 5px; border-bottom: 1px solid #414868; color: #9ece6a; font-size: 1.1rem; }
        input[type=range] { width: 100px; }
        input[type=number] { font-family: Karla, sans-serif; width: 50px; background-color: #1a1b26; color: #c0caf5; border: 1px solid #414868; padding: 4px; border-radius: 4px; }
        #close-settings { width: 100%; margin-top: 15px; font-family: Karla, sans-serif; }
        .footer-signature { position: fixed; top: 2px; right: 2px; font-size: .8rem; color: #565f89; pointer-events: none; z-index: 60; }
    </style>
</head>
<body>
    <a href="/" class="home-button"><h1>Home</h1></a>
    <div id="status">MIDI Connected.</div>
    <div id="chord-display">
        <div id="chord-degree"></div>
        <div id="chord-name" class="chord-gradient-text"><span style="font-style:normal; font-weight:normal;">- - -</span></div>
    </div>
    
    <div class="instrument-wrapper" id="main-scroll-wrapper">
        <canvas id="trails-canvas" style="display: block;"></canvas>
        <div id="piano" class="show-all-labels" style="display: flex;"></div>
        <div id="fretboard-container" style="display: none;"></div>
    </div>

    <div id="mini-tuner" style="display: none; position: fixed; bottom: 20px; right: 20px; width: 220px; background: var(--panel-bg); border: 1px solid #414868; border-radius: 10px; padding: 15px; z-index: 100; box-shadow: 0 10px 30px rgba(0,0,0,0.8);">
        <div style="text-align:center; font-family: 'Kinnari', 'Karla', sans-serif; font-size: 2.5rem; font-weight:bold; color: var(--chord-text-colour); line-height: 1;" id="mini-note">-</div>
        <div id="mini-cents" style="text-align: center; font-size: 0.7rem; color: #565f89; margin-top: 5px; font-weight: bold;">AWAITING SIGNAL</div>
        <div class="meter-bg" style="width: 100%; height: 6px; background: var(--bg-colour); position: relative; margin-top: 15px; border-radius: 3px; border: 1px solid #414868;">
            <div class="center-mark" style="position: absolute; left: 50%; top: -5px; width: 2px; height: 16px; background: #9ece6a; transform: translateX(-50%);"></div>
            <div id="mini-needle" style="width: 4px; height: 20px; background: var(--chord-text-colour); position: absolute; top: -7px; left: 50%; transform: translateX(-50%); transition: left 0.1s linear; border-radius: 2px;"></div>
        </div>
    </div>

    <div class="controls-container">
        <button id="btn-settings">⚙️ Settings</button>
        <select id="instrument-selector">
            <option value="piano" selected="selected">Piano</option>
            <option value="guitar">Guitar</option>
        </select>
        <select id="audio-input-selector">
            <option value="default">Loading Inputs...</option>
        </select>
        <select id="scale-root">
            <option value="none">No Scale</option>
            <option value="0">C</option>
            <option value="1">C#</option>
            <option value="2">D</option>
            <option value="3">D#</option>
            <option value="4">E</option>
            <option value="5">F</option>
            <option value="6">F#</option>
            <option value="7">G</option>
            <option value="8">G#</option>
            <option value="9">A</option>
            <option value="10">A#</option>
            <option value="11">B</option>
        </select>
        <select id="scale-type">
            <option value="Major">Major (Ionian)</option>
            <option value="Minor">Natural Minor (Aeolian)</option>
            <option value="Harmonic Minor">Harmonic Minor</option>
            <option value="Dorian">Dorian</option>
            <option value="Phrygian">Phrygian</option>
            <option value="Lydian">Lydian</option>
            <option value="Mixolydian">Mixolydian</option>
            <option value="Locrian">Locrian</option>
            <option value="Major Pentatonic">Major Pentatonic</option>
            <option value="Minor Pentatonic">Minor Pentatonic</option>
            <option value="Blues">Blues</option>
            <option value="Diminished">Diminished</option>
        </select>
        <div id="diatonic-chords-container"></div>
    </div>
    
    <div class="footer-signature">by Marcel Köberlin</div>
    
    <div id="settings-panel">
        <h3 style="margin-top:0;text-align:center">Settings</h3>
        <div class="setting-section-title">Audio Options</div>
        <div class="setting-row">
            <label>Mute Instrument Sound</label>
            <input type="checkbox" id="mute-instrument" checked="checked">
        </div>
        <div class="setting-section-title">Visuals</div>
        <div class="setting-row">
            <label>Note Naming</label>
            <select id="accidental-selector">
                <option value="logic" selected="selected">Logic Pro (Db, Eb, F#, Ab, Bb)</option>
                <option value="sharps">Sharps (C#, D#, etc.)</option>
                <option value="flats">Flats (Db, Eb, etc.)</option>
                <option value="mixed">Mixed (C#, Eb, F#, Ab, Bb)</option>
            </select>
        </div>
        <div class="setting-section-title">Piano Options</div>
        <div class="setting-row">
            <label>Keyboard Size</label>
            <select id="size-selector">
                <option value="25">25 Keys</option>
                <option value="37">37 Keys</option>
                <option value="49">49 Keys</option>
                <option value="61">61 Keys</option>
                <option value="76">76 Keys</option>
                <option value="88">88 Keys</option>
            </select>
        </div>
        <div class="setting-row">
            <label>Show Note Labels</label>
            <select id="label-selector">
                <option value="show-all-labels">All Keys</option>
                <option value="labels-white-only">White Keys Only</option>
                <option value="labels-black-only">Black Keys Only</option>
                <option value="hide-labels">None</option>
            </select>
        </div>
        <div class="setting-section-title">Guitar Options</div>
        <div class="setting-row">
            <label>Start Fret</label>
            <input type="number" id="fret-start" min="0" max="24" value="0">
        </div>
        <div class="setting-row">
            <label>End Fret</label>
            <input type="number" id="fret-end" min="1" max="24" value="12">
        </div>
        <button id="close-settings">Close &amp; Save</button>
    </div>

    <script>
        const NOTE_NAMINGS = {
            sharps: ["C", "C#", "D", "D#", "E", "F", "F#", "G", "G#", "A", "A#", "B"],
            flats: ["C", "Db", "D", "Eb", "E", "F", "Gb", "G", "Ab", "A", "Bb", "B"],
            mixed: ["C", "C#", "D", "Eb", "E", "F", "F#", "G", "Ab", "A", "Bb", "B"],
            logic: ["C", "Db", "D", "Eb", "E", "F", "F#", "G", "Ab", "A", "Bb", "B"]
        };
        let isMuted = true;
        let chordFadeTimeout, completeFadeTimeout, noteReleaseTimeout;
        let isMidiFading = false;
        let NOTE_NAMES = NOTE_NAMINGS.sharps;
        let activeNotes = new Set();
        let currentInstrument = "piano";

        // Tuner global variables
        let audioTrackingActive = false;
        let analyserNode;
        let tunerDataArray;
        let smoothedPitch = 0;
        let medianBuffer = [];
        const MEDIAN_SIZE = 5;

        const defaultSettings = {
            "--chord-text-colour": "#ff8f00",
            "--pressed-white-bg": "#ff8f00",
            "--pressed-black-bg": "#ff00cb",
            "--white-key-bg": "#CAE5FF",
            "--black-key-bg": "#12355B"
        };
        const defaultUiSettings = {
            accidentalMode: "logic",
            pianoSize: "76",
            scaleRoot: "none",
            scaleType: "Major",
            pianoLabels: "show-all-labels",
            fretStart: "0",
            fretEnd: "12",
            instrument: "piano",
            muteInstrument: true
        };

        function loadSettings() {
            const e = document.documentElement.style;
            for (const [t, n] of Object.entries(defaultSettings)) e.setProperty(t, n);
            document.getElementById("size-selector").value = defaultUiSettings.pianoSize;
            document.getElementById("accidental-selector").value = defaultUiSettings.accidentalMode;
            NOTE_NAMES = NOTE_NAMINGS[defaultUiSettings.accidentalMode];
            document.getElementById("scale-root").value = defaultUiSettings.scaleRoot;
            document.getElementById("scale-type").value = defaultUiSettings.scaleType;
            document.getElementById("label-selector").value = defaultUiSettings.pianoLabels;
            document.getElementById("fret-start").value = defaultUiSettings.fretStart;
            document.getElementById("fret-end").value = defaultUiSettings.fretEnd;
            document.getElementById("instrument-selector").value = defaultUiSettings.instrument;
            applyInstrumentLayout();
            const muteCheckbox = document.getElementById("mute-instrument");
            if (muteCheckbox) {
                muteCheckbox.checked = defaultUiSettings.muteInstrument;
                isMuted = defaultUiSettings.muteInstrument;
            }
        }

        function saveSettings() {}

        let audioCtx;
        const activeOscillators = {};

        function initAudio() {
            if (!audioCtx) {
                const e = window.AudioContext || window.webkitAudioContext;
                audioCtx = new e();
            }
            if ("suspended" === audioCtx.state) audioCtx.resume();
        }

        function playSound(e) {
            if (isMuted) return; // Halt sound generation if muted
            
            initAudio();
            if (!activeOscillators[e]) {
                "piano" === currentInstrument ? playPianoSound(e) : playGuitarSound(e);
            }
        }

        function playPianoSound(e) {
            const t = audioCtx.createGain(), n = 440 * Math.pow(2, (e - 69) / 12);
            t.gain.setValueAtTime(0, audioCtx.currentTime);
            t.gain.linearRampToValueAtTime(.15, audioCtx.currentTime + .015);
            t.gain.exponentialRampToValueAtTime(.001, audioCtx.currentTime + 2.5);
            const a = audioCtx.createOscillator();
            a.type = "triangle";
            a.frequency.value = n;
            const o = audioCtx.createBiquadFilter();
            o.type = "lowpass";
            o.frequency.value = Math.min(3 * n, 3e3);
            a.connect(o);
            o.connect(t);
            t.connect(audioCtx.destination);
            a.start();
            activeOscillators[e] = { osc: a, gainNode: t };
        }

        function playGuitarSound(e) {
            const t = audioCtx.createGain(), n = 440 * Math.pow(2, (e - 69) / 12);
            t.gain.setValueAtTime(0, audioCtx.currentTime);
            t.gain.linearRampToValueAtTime(.2, audioCtx.currentTime + .005);
            t.gain.exponentialRampToValueAtTime(.001, audioCtx.currentTime + 3);
            const a = audioCtx.createOscillator();
            a.type = "sawtooth";
            a.frequency.value = n;
            const o = audioCtx.createBiquadFilter();
            o.type = "lowpass";
            o.frequency.setValueAtTime(Math.min(8 * n, 6e3), audioCtx.currentTime);
            o.frequency.exponentialRampToValueAtTime(Math.max(1.5 * n, 300), audioCtx.currentTime + .5);
            a.connect(o);
            o.connect(t);
            t.connect(audioCtx.destination);
            a.start();
            activeOscillators[e] = { osc: a, gainNode: t };
        }

        function stopSound(e) {
            if (activeOscillators[e]) {
                const { osc: t, gainNode: n } = activeOscillators[e], a = audioCtx.currentTime;
                n.gain.cancelScheduledValues(a);
                n.gain.setValueAtTime(n.gain.value, a);
                n.gain.exponentialRampToValueAtTime(1e-4, a + .1);
                n.gain.setValueAtTime(0, a + .11);
                t.stop(a + .15);
                delete activeOscillators[e];
            }
        }

        const SCALE_INTERVALS = {
            "Major": [0, 2, 4, 5, 7, 9, 11],
            "Minor": [0, 2, 3, 5, 7, 8, 10],
            "Harmonic Minor": [0, 2, 3, 5, 7, 8, 11],
            "Dorian": [0, 2, 3, 5, 7, 9, 10],
            "Phrygian": [0, 1, 3, 5, 7, 8, 10],
            "Lydian": [0, 2, 4, 6, 7, 9, 11],
            "Mixolydian": [0, 2, 4, 5, 7, 9, 10],
            "Locrian": [0, 1, 3, 5, 6, 8, 10],
            "Major Pentatonic": [0, 2, 4, 7, 9],
            "Minor Pentatonic": [0, 3, 5, 7, 10],
            "Blues": [0, 3, 5, 6, 7, 10],
            "Diminished": [0, 2, 3, 5, 6, 8, 9, 11]
        };

        function getValidPitchClasses() {
            const e = document.getElementById("scale-root").value;
            const t = document.getElementById("scale-type").value;
            if ("none" === e) return null;
            const n = parseInt(e);
            return SCALE_INTERVALS[t].map(e => (n + e) % 12);
        }

        function updateScaleHighlight() {
            document.querySelectorAll(".in-scale").forEach(e => e.classList.remove("in-scale"));
            document.querySelectorAll(".hover-chord-key").forEach(e => e.classList.remove("hover-chord-key"));
            const e = document.getElementById("diatonic-chords-container");
            if (e) e.innerHTML = "";
            const t = getValidPitchClasses();
            if (t) {
                for (let e = 21; e <= 108; e++) {
                    if (t.includes(e % 12)) {
                        const n = document.getElementById(`note-${e}`);
                        if (n) n.classList.add("in-scale");
                        document.querySelectorAll(`.fret-cell[data-note="${e}"]`).forEach(e => e.classList.add("in-scale"));
                    }
                }
                if (7 === t.length && e) renderDiatonicChords(t, e);
            }
        }

        function renderDiatonicChords(e, t) {
            const n = ["I", "II", "III", "IV", "V", "VI", "VII"];
            for (let a = 0; a < 7; a++) {
                let o = e[a], i = e[(a + 2) % 7], s = e[(a + 4) % 7], l = (i - o + 12) % 12, r = (s - o + 12) % 12, c = "", d = n[a];
                if (4 === l && 7 === r) c = "maj";
                else if (3 === l && 7 === r) { c = "min"; d = d.toLowerCase(); }
                else if (3 === l && 6 === r) { c = "dim"; d = d.toLowerCase() + "°"; }
                else if (4 === l && 8 === r) { c = "aug"; d += "+"; }
                let u = document.createElement("div");
                u.className = "diatonic-chord-item";
                u.dataset.degree = a;
                u.dataset.chordType = c || "";
                u.id = `diatonic-chord-${a}`;
                u.innerHTML = `<strong>${d}.</strong> ${NOTE_NAMES[o]}${c}`;
                
                let pcs = [o, i, s];
                
                u.addEventListener("mouseenter", () => {
                    for (let f = 21; f <= 108; f++) {
                        if (pcs.includes(f % 12)) {
                            let key = document.getElementById(`note-${f}`);
                            if (key && "piano" === currentInstrument) key.classList.add("hover-chord-key");
                            
                            if ("guitar" === currentInstrument) {
                                document.querySelectorAll(`.fret-cell[data-note="${f}"] .fret-marker`).forEach(marker => {
                                    marker.classList.add("hover-chord-fret");
