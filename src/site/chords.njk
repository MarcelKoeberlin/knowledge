                    document.querySelectorAll(".hover-chord-fret").forEach(marker => marker.classList.remove("hover-chord-fret"));
                });
                t.appendChild(u);
            }
        }

        // --- Tuner AutoCorrelate function ---
        function autoCorrelate(buffer, sampleRate) {
            let rms = 0;
            for (let i = 0; i < buffer.length; i++) rms += buffer[i] * buffer[i];
            if (Math.sqrt(rms / buffer.length) < 0.01) return -1; 

            let c = new Float32Array(buffer.length).fill(0);
            for (let i = 0; i < buffer.length; i++) {
                for (let j = 0; j < buffer.length - i; j++) {
                    c[i] = c[i] + buffer[j] * buffer[j + i];
                }
            }
            let d = 0; while (c[d] > c[d + 1]) d++;
            let maxval = -1, T0 = -1;
            for (let i = d; i < buffer.length; i++) {
                if (c[i] > maxval) { maxval = c[i]; T0 = i; }
            }

            let shift = 0;
            if (T0 > 0 && T0 < buffer.length - 1) {
                let y1 = c[T0 - 1], y2 = c[T0], y3 = c[T0 + 1];
                shift = (y1 - y3) / (2 * (y1 - 2 * y2 + y3));
            }

            return sampleRate / (T0 + shift);
        }

        function trackPitch() {
            if (!audioTrackingActive) return;
            requestAnimationFrame(trackPitch);

            // Strict MIDI Priority Gate: Halt audio if MIDI is active or fading out
            if (activeNotes.size > 0 || isMidiFading) return;
            
            // ... rest of the function remains the same

            analyserNode.getFloatTimeDomainData(tunerDataArray);
            let rawPitch = autoCorrelate(tunerDataArray, audioCtx.sampleRate);
            
            if (rawPitch !== -1 && rawPitch < 2000) {
                medianBuffer.push(rawPitch);
                if (medianBuffer.length > MEDIAN_SIZE) medianBuffer.shift();
                
                let sorted = [...medianBuffer].sort((a, b) => a - b);
                let medianPitch = sorted[Math.floor(sorted.length / 2)];

                smoothedPitch = (0.2 * medianPitch) + (0.8) * (smoothedPitch || medianPitch);
                
                const midi = Math.round(12 * Math.log2(smoothedPitch / 440)) + 69;
                const noteName = NOTE_NAMES[midi % 12];
                const cents = Math.floor(1200 * Math.log2(smoothedPitch / (440 * Math.pow(2, (midi - 69) / 12))));

                // Always update the mini-tuner UI so it functions while playing
                document.getElementById('mini-note').innerText = noteName;
                document.getElementById('mini-cents').innerText = (cents > 0 ? "+" : "") + cents + " CENTS";
                
                const needle = document.getElementById('mini-needle');
                let displayCents = Math.max(-50, Math.min(50, cents));
                needle.style.left = (50 + displayCents) + "%";
                
                if (Math.abs(cents) <= 3) {
                    needle.style.background = '#9ece6a';
                } else {
                    needle.style.background = 'var(--chord-text-colour)';
                }

                // MIDI Absolute Priority Gate
                // If any MIDI notes are held, we skip updating the large chord text entirely
                if (activeNotes.size === 0) {
                    const display = document.getElementById('chord-display');
                    const degree = document.getElementById('chord-degree');
                    display.style.opacity = '1';
                    if(degree) degree.textContent = "";
                    document.getElementById('chord-name').innerHTML = `<span style="font-weight:bold;">${noteName}</span>`;
                }
            }
        }

        let mediaStream = null;

        async function initialiseGuitarAudio() {
            if (!navigator.mediaDevices) return;
            
            if (selectedAudioDeviceId === 'none') {
                audioTrackingActive = false;
                document.getElementById('mini-note').innerText = "-";
                document.getElementById('mini-cents').innerText = "AUDIO OFF";
                return;
            }

            try {
                if (mediaStream) {
                    mediaStream.getTracks().forEach(track => track.stop());
                }

                const constraints = selectedAudioDeviceId === 'default' 
                    ? { audio: true } 
                    : { audio: { deviceId: { exact: selectedAudioDeviceId } } };

                mediaStream = await navigator.mediaDevices.getUserMedia(constraints);
                initAudio(); 
                
                const source = audioCtx.createMediaStreamSource(mediaStream);
                analyserNode = audioCtx.createAnalyser();
                analyserNode.fftSize = 4096;
                source.connect(analyserNode);
                tunerDataArray = new Float32Array(analyserNode.fftSize);
                audioTrackingActive = true;
                
                trackPitch();
            } catch (error) {
                console.warn("Audio access denied.", error);
            }
        }

