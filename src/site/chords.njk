        async function populateAudioSelector() {
            if (!navigator.mediaDevices) return;

            try {
                // Request initial permission to access device labels
                await navigator.mediaDevices.getUserMedia({ audio: true }); 
                const devices = await navigator.mediaDevices.enumerateDevices();
                availableAudioDevices = devices.filter(d => d.kind === 'audioinput');

                const selector = document.getElementById("audio-input-selector");
                selector.innerHTML = '';

                const midiOffOption = document.createElement('option');
                midiOffOption.value = 'none';
                midiOffOption.text = 'MIDI Only (Audio Off)';
                selector.appendChild(midiOffOption);

                availableAudioDevices.forEach(device => {
                    const option = document.createElement('option');
                    option.value = device.deviceId;
                    option.text = device.label || 'Unknown Microphone';
                    selector.appendChild(option);
                });

                // Determine priority
                const midiAccess = await navigator.requestMIDIAccess().catch(() => null);
                const hasMidi = midiAccess && midiAccess.inputs.size > 0;

                if (hasMidi) {
                    selector.value = 'none';
                    selectedAudioDeviceId = 'none';
                } else {
                    const interfaceRegex = /(usb|interface|scarlett|focusrite|behringer|audient|presonus|steinberg|motu|rme|ua|apollo)/i;
                    const interfaceDevice = availableAudioDevices.find(d => interfaceRegex.test(d.label));
                    
                    if (interfaceDevice) {
                        selector.value = interfaceDevice.deviceId;
                        selectedAudioDeviceId = interfaceDevice.deviceId;
                    } else if (availableAudioDevices.length > 0) {
                        selector.value = availableAudioDevices[0].deviceId;
                        selectedAudioDeviceId = availableAudioDevices[0].deviceId;
                    }
                }

                selector.addEventListener('change', (e) => {
                    selectedAudioDeviceId = e.target.value;
                    if (currentInstrument === 'guitar') {
                        initialiseGuitarAudio();
                    }
                });

            } catch (error) {
                console.warn("Could not enumerate audio devices.", error);
            }
        }

        // Initialise the selector on load
        window.addEventListener('load', populateAudioSelector);
        loadSettings();
        updateChordDisplay(activeNotes);
    </script>
</body>
</html>