                        }, 1000);
                    }, 2000);
                }
            const n = trails.find(t => t.note === e && t.active);
            if (n) {
                n.active = false;
                n.endTime = performance.now();
            }
            if ("piano" === currentInstrument) {
                            const t = document.getElementById(`note-${e}`);
                            if (t) t.classList.remove("active");
                        } else {
                            document.querySelectorAll(`.fret-cell[data-note="${e}"] .fret-marker`).forEach(e => e.classList.remove("active"));
                        }
                    }

        function getMIDIMessage(e) {
            const t = e.data[0], n = e.data[1], a = e.data.length > 2 ? e.data[2] : 0;
