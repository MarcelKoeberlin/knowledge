        function getChordNameHTML(e, t, n, a) {
            let o = `<div class="chord-gradient-text"><span style="font-weight:bold; font-style:normal;">${e}</span><span style="font-weight:normal; font-style:italic;"> ${t}</span>`;
            if (n && n !== e) o += `<span style="font-weight:normal; font-style:italic;">/${n.toLowerCase()}</span>`;
            if (a) o += `<span style="font-size: 0.2em; font-weight:normal; font-style:italic; display:inline-block; margin-left:0.8em;">${a}</span>`;
            o += "</div>";
            return o;
        }

        function getChordName(e) {
            if (0 === e.size) return { html: "<span style='font-style:normal; font-weight:normal;'>- - -</span>", root: null, type: null, inversion: null };
            let t = Array.from(e).sort((e, t) => e - t);
            let n = t[0] % 12;
            let a = Array.from(new Set(t.map(e => e % 12)));
            if (a.length < 2) return { html: getChordNameHTML(NOTE_NAMES[a[0]], "", "", ""), root: a[0], type: "", inversion: "" };
            if (a.length < 3 && a.includes((n + 7) % 12)) return { html: getChordNameHTML(NOTE_NAMES[n], "5", "", ""), root: n, type: "5", inversion: "" };
            
            const o = [
                { type: "13", intervals: [4, 7, 10, 2, 9] }, { type: "maj13", intervals: [4, 7, 11, 2, 9] }, { type: "min13", intervals: [3, 7, 10, 2, 9] },
                { type: "11", intervals: [4, 7, 10, 2, 5] }, { type: "maj11", intervals: [4, 7, 11, 2, 5] }, { type: "min11", intervals: [3, 7, 10, 2, 5] },
                { type: "9", intervals: [4, 7, 10, 2] }, { type: "maj9", intervals: [4, 7, 11, 2] }, { type: "min9", intervals: [3, 7, 10, 2] },
                { type: "7b9", intervals: [4, 7, 10, 1] }, { type: "7#9", intervals: [4, 7, 10, 3] }, { type: "m7b9", intervals: [3, 7, 10, 1] },
                { type: "9sus4", intervals: [5, 7, 10, 2], avoid: [3, 4] }, { type: "6/9", intervals: [4, 7, 9, 2] }, { type: "m6/9", intervals: [3, 7, 9, 2] },
                { type: "maj7", intervals: [4, 7, 11] }, { type: "7", intervals: [4, 7, 10] }, { type: "min7", intervals: [3, 7, 10] },
                { type: "m7b5", intervals: [3, 6, 10] }, { type: "dim7", intervals: [3, 6, 9] }, { type: "mM7", intervals: [3, 7, 11] },
                { type: "aug7", intervals: [4, 8, 10] }, { type: "augM7", intervals: [4, 8, 11] }, { type: "7b5", intervals: [4, 6, 10] },
                { type: "7sus4", intervals: [5, 7, 10], avoid: [3, 4] }, { type: "maj6", intervals: [4, 7, 9] }, { type: "min6", intervals: [3, 7, 9] },
                { type: "add9", intervals: [4, 7, 2] }, { type: "madd9", intervals: [3, 7, 2] }, { type: "add4", intervals: [4, 7, 5] },
                { type: "sus4", intervals: [5, 7], avoid: [3, 4] }, { type: "sus2", intervals: [2, 7], avoid: [3, 4] },
                { type: "maj", intervals: [4, 7] }, { type: "min", intervals: [3, 7] }, { type: "dim", intervals: [3, 6] }, { type: "aug", intervals: [4, 8] }
            ];
            let i = null, s = [n, ...a.filter(e => e !== n)];
            for (let e of s) {
                let t = a.map(t => (t - e + 12) % 12);
                let s = e => t.includes(e);
                let l = o.find(e => {
                    let t = e.intervals.every(e => s(e));
                    let n = !e.avoid || e.avoid.every(e => !s(e));
                    return t && n;
                });
                if (l) {
                    let t = l.intervals.length + 1;
                    let o = a.length - t;
                    if (o <= 1) {
                        let t = 10 * l.intervals.length - 5 * o;
                        if (e === n) t += 20;
                        if (!i || t > i.score) {
                            i = { root: e, type: l.type, score: t, matchLengths: l.intervals.length };
                        }
                    }
                }
            }
            if (i) {
                let e = NOTE_NAMES[i.root], t = i.type, a = NOTE_NAMES[n], o = "";
                if (i.root !== n) {
                    let e = (n - i.root + 12) % 12;
                    if (3 === e || 4 === e) o = "1st inversion";
                    else if (7 === e || 6 === e) o = "2nd inversion";
                    else if (10 === e || 11 === e || 9 === e) o = "3rd inversion";
                    else o = "inverted";
                } else {
                    o = "root";
                }
                return { html: getChordNameHTML(e, t, a, o), root: i.root, type: t, inversion: o };
            }
            return { html: "<div class='chord-gradient-text'><span style='font-style:normal; font-weight:bold;'>?</span></div>", root: null, type: null, inversion: null };
        }

        function updateChordDisplay(e) {
            const t = document.getElementById("chord-name"), n = document.getElementById("chord-degree");
